#!/usr/bin/env bash
set -e

# Clear git env vars so tests can create their own repos.
# GIT_CEILING_DIRECTORIES prevents git from walking up into the
# parent repo when tests run git commands in temp directories.
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE
export GIT_CEILING_DIRECTORIES="/"

go vet ./...
go test ./...
